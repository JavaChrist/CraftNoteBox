# Copie vers .env.local et remplis les valeurs (Supabase → Project Settings → API)
#
# IMPORTANT : il y a DEUX clés JWT sur la page API :
#   - « anon » / « public »  → NEXT_PUBLIC_SUPABASE_ANON_KEY (ou SUPABASE_ANON_KEY)
#   - « service_role » secret → SUPABASE_SERVICE_ROLE_KEY uniquement serveur
# La clé secrète seule ne remplace pas la clé anon.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Variante acceptée (CLI Supabase) — next.config les mappe vers NEXT_PUBLIC_*
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server Actions — ne jamais commiter ni exposer au client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optionnel : UUID pour tester sans login en dev (voir README)
# DEV_SUPABASE_USER_ID=

# JavaChrist (OpenAI) — clé serveur uniquement, jamais NEXT_PUBLIC_*
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
